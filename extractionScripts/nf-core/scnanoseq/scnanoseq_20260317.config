// Store configs for scnanoseq pipeline execution here
workDir = '/projects/b1042/GoyalLab/egrody/extractedData/EGS025/nf-core/work/'

params {
   input = '/home/egy2296/SALVEseq/extractionScripts/nf-core/scnanoseq/EGS024_sampleSheet.csv'
   outdir = '/projects/b1042/GoyalLab/egrody/extractedData/EGS025/nf-core/'
   genome_fasta = '/projects/b1042/GoyalLab/egrody/genomes/mac239/fasta/genome.fa'
   gtf = '/projects/b1042/GoyalLab/egrody/genomes/mac239/genes/mac239_fixed.gtf'
   barcode_format = '10X_3v4'
   quantifier = 'isoquant'
}
profiles {
   cluster {
       process.executor = 'slurm'
       executor.queueSize = 10     // Specify size of queue
       process.cpu = '20'          // --cpus-per-task
       process.memory = '100 GB'   // Memory limit for each job
       process.queue = 'genomics'  // Equivalent to --partition
       process.clusterOptions = '--account=b1042'      // Specify account
       process.beforeScript = 'module load singularity'
   }
   singularity {
       singularity.enabled = true
       singularity.cacheDir = '.singularity_cache' // Singularity images cache
   }
}

// Override time limits that exceed genomics partition max (48h)
process {
    withLabel:process_long {
        time = 48.h
    }
}
