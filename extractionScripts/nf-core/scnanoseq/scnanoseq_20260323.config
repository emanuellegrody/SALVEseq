// Store configs for scnanoseq pipeline execution here
workDir = '/projects/b1042/GoyalLab/egrody/extractedData/EGL003/nf-core/work/'

params {
   input = '/home/egy2296/SALVEseq/extractionScripts/nf-core/scnanoseq/EGL003_sampleSheet.csv'
   outdir = '/projects/b1042/GoyalLab/egrody/extractedData/EGL003/nf-core/'
   genome_fasta = '/projects/b1042/GoyalLab/egrody/genomes/GRCm39/fasta/genome.fa'
   gtf = '/projects/b1042/GoyalLab/egrody/genomes/GRCm39/genes/genes.gtf.gz'
   barcode_format = '10X_3v3'
   quantifier = 'isoquant'
}
profiles {
   cluster {
       process.executor = 'slurm'
       executor.queueSize = 10     // Specify size of queue
       process.cpu = '20'          // --cpus-per-task
       process.memory = '100 GB'   // Memory limit for each job
       process.queue = 'genomics'  // Equivalent to --partition
       process.clusterOptions = '--account=b1042'      // Specify account
       process.beforeScript = 'module load singularity'
   }
   singularity {
       singularity.enabled = true
       singularity.cacheDir = '.singularity_cache' // Singularity images cache
   }
}

// Override time limits that exceed genomics partition max (48h)
process {
    withLabel:process_long {
        time = 48.h
    }
}
